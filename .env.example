# Environment Variables for FitSense
# Copy this file to .env and fill in your values
# Get these from: https://supabase.com → Your Project → Settings → API

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
REACT_APP_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anon/public key — must be a JWT token starting with eyJ...
# Go to: Settings → API → "Legacy anon, service_role API keys" tab
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here
